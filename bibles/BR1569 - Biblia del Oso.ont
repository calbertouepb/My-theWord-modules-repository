\fs56 CASIODORO DE REINA\b0\fs24  \par\
\f1\fs52 1569\f0\fs24  \par\
\par\par\
\f1\fs32 LA BIBLIA QVE ES, LOS SACROS LIBROS DEL VIEIO Y NVEVO TESTAMENTO.\f0\fs24  \par\
\f1\fs28 Trasladada en Espa\'f1ol\par\
\par\
\i\fs24 La Palabra del Dios nuestro permanece para siempre.\i0  \par\
\par\Isa. 40\f0\par\
\par\M.D.LXIX\f0  \par\
\cf1\i\f1\fs22\par\
