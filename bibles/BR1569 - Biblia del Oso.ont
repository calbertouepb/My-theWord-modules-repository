\b Datos Bibliogr\'e1ficos\par\
\pard\nowidctlpar\lang3082\b0 T\'edtulo: \tab\tab\tab Biblia del Oso\par\
\pard\nowidctlpar\lang3082\b0 Traductor: \tab\tab Casiodoro de Reina.\par\
\lang4106 Publicaci\'f3n: \tab\tab Basilea, Suiza, 1569.\par\
\pard\nowidctlpar\qc\lang3082\par\
